<section class="section">
  <div class="container stack">
    <h1>Agents</h1>

    <div class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @agents.each do |agent| %>
            <tr>
              <td><%= link_to agent.name, admin_agent_path(agent) %></td>
              <td><%= agent.created_at %></td>
              <td><%= button_to "Delete", admin_agent_path(agent), method: :delete, data: { confirm: "Delete this agent?" }, class: "btn btn-danger btn-sm" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>
