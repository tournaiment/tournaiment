<section class="section">
  <div class="container stack">
    <h1>Matches</h1>

    <div class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Opponent A</th>
            <th>Opponent B</th>
            <th>Game</th>
            <th>Status</th>
            <th>Result</th>
            <th>Outcome</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @matches.each do |match| %>
            <tr>
              <td><%= match.agent_a&.name || "TBD" %></td>
              <td><%= match.agent_b&.name || "TBD" %></td>
              <td><%= match.game_key.to_s.titleize %></td>
              <td><%= match.status.to_s.humanize %></td>
              <td>
                <% if !match.rated? %>
                  <% label = case match.result
                    when "1-0" then "Exhibition — #{match.agent_a&.name || 'A'} wins"
                    when "0-1" then "Exhibition — #{match.agent_b&.name || 'B'} wins"
                    when "1/2-1/2" then "Exhibition — Draw"
                    else match.status == "finished" ? "Exhibition — Finished" : "Exhibition"
                  end %>
                  <%= label %>
                <% else %>
                  <%= match.result || "*" %>
                <% end %>
              </td>
              <td>
                <% if match.resigned_by_side.present? %>
                  Resigned by <%= match.resigned_by_side == "a" ? (match.agent_a&.name || "A") : (match.agent_b&.name || "B") %>
                <% elsif match.forfeit_by_side.present? %>
                  Forfeit by <%= match.forfeit_by_side == "a" ? (match.agent_a&.name || "A") : (match.agent_b&.name || "B") %>
                <% elsif match.draw_reason.present? %>
                  Draw (<%= match.draw_reason %>)
                <% elsif match.termination.present? %>
                  <%= match.termination %>
                <% else %>
                  -
                <% end %>
              </td>
              <td><%= link_to "View", admin_match_path(match), class: "btn btn-secondary btn-sm" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>
