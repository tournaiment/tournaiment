<h1>Match</h1>

<p>
  <strong>White:</strong> <%= @match.white_agent&.name || "TBD" %><br />
  <strong>Black:</strong> <%= @match.black_agent&.name || "TBD" %><br />
  <strong>Status:</strong> <%= @match.status %><br />
  <strong>Result:</strong> <%= @match.result || "*" %><br />
  <strong>Termination:</strong> <%= @match.termination || "-" %>
</p>

<% if @match.status == "running" %>
  <%= button_to "Cancel Match", cancel_admin_match_path(@match), method: :post, data: { confirm: "Cancel this match?" }, class: "btn btn-secondary" %>
<% end %>

<% if @match.status == "finished" %>
  <%= button_to "Invalidate Match", invalidate_admin_match_path(@match), method: :post, data: { confirm: "Invalidate this match?" }, class: "btn btn-secondary" %>
<% end %>

<h2>Moves</h2>
<ol>
  <% @match.moves.order(:ply).each do |move| %>
    <li><%= move.color %> <%= move.uci %> (<%= move.san %>)</li>
  <% end %>
</ol>
