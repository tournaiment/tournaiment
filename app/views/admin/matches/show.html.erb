<section class="section">
  <div class="container stack">
    <h1>Match</h1>

    <div class="card stack">
      <p>
        <strong>Opponent A:</strong> <%= @match.agent_a&.name || "TBD" %><br />
        <strong>Opponent B:</strong> <%= @match.agent_b&.name || "TBD" %><br />
        <strong>Game:</strong> <%= @match.game_key.to_s.titleize %><br />
        <strong>Status:</strong> <%= @match.status.to_s.humanize %><br />
        <strong>Result:</strong> <%= @match.result || "*" %><br />
        <strong>Termination:</strong> <%= @match.termination || "-" %><br />
        <% if @match.resigned_by_side.present? %>
          <strong>Resigned By:</strong>
          <%= @match.resigned_by_side == "a" ? (@match.agent_a&.name || "Opponent A") : (@match.agent_b&.name || "Opponent B") %><br />
        <% end %>
        <% if @match.forfeit_by_side.present? %>
          <strong>Forfeit By:</strong>
          <%= @match.forfeit_by_side == "a" ? (@match.agent_a&.name || "Opponent A") : (@match.agent_b&.name || "Opponent B") %><br />
        <% end %>
        <% if @match.draw_reason.present? %>
          <strong>Draw Reason:</strong> <%= @match.draw_reason %>
        <% end %>
      </p>

      <div class="cta-row">
        <% if @match.status == "running" %>
          <%= button_to "Cancel Match", cancel_admin_match_path(@match), method: :post, data: { confirm: "Cancel this match?" }, class: "btn btn-secondary" %>
        <% end %>

        <% if @match.status == "finished" %>
          <%= button_to "Invalidate Match", invalidate_admin_match_path(@match), method: :post, data: { confirm: "Invalidate this match?" }, class: "btn btn-secondary" %>
        <% end %>
      </div>
    </div>

    <div class="card">
      <h2>Moves</h2>
      <ol class="move-list">
        <% @match.moves.order(:ply).each do |move| %>
          <li><%= move.actor %> <%= move.notation %> (<%= move.display %>)</li>
        <% end %>
      </ol>
    </div>
  </div>
</section>
