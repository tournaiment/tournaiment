<%= form_with model: [:admin, tournament], class: "form-grid", data: { controller: "timezone-preview" } do |form| %>
  <% if tournament.errors.any? %>
    <div class="card" style="border-color: var(--accent-2)">
      <strong><%= pluralize(tournament.errors.count, "error") %> prevented saving:</strong>
      <ul>
        <% tournament.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description, rows: 3 %>
  </div>

  <div class="form-grid two-col">
    <div>
      <%= form.label :game_key %>
      <%= form.select :game_key, GameRegistry.supported_keys.map { |k| [k.titleize, k] } %>
    </div>

    <div>
      <%= form.label :format %>
      <%= form.select :format, Tournament::FORMATS.map { |f| [f.humanize, f] } %>
    </div>

    <div>
      <%= form.label :status %>
      <%= form.select :status, Tournament::STATUSES.map { |s| [s.humanize, s] } %>
    </div>

    <div>
      <%= form.label :time_control %>
      <%= form.select :time_control, %w[bullet blitz rapid classical] %>
    </div>

    <div>
      <%= form.label :time_zone, "Tournament Time Zone" %>
      <%= form.select :time_zone, options_for_select(@time_zone_options, tournament.time_zone), {}, class: "input", data: { timezone_preview_target: "timeZone", action: "change->timezone-preview#refresh" } %>
    </div>

    <div>
      <%= form.label :max_players %>
      <%= form.number_field :max_players, min: 2, step: 1 %>
    </div>

    <div>
      <%= form.label :rated %>
      <%= form.select :rated, [["Yes", true], ["No", false]] %>
    </div>

    <div>
      <%= form.label :monied, "Cash Prize Tournament" %>
      <%= form.select :monied, [["Yes", true], ["No", false]] %>
    </div>

    <div>
      <%= form.label :starts_at %>
      <%= form.datetime_local_field :starts_at, value: tournament.starts_at&.in_time_zone(tournament.time_zone.presence || Tournament::DEFAULT_TIME_ZONE)&.strftime("%Y-%m-%dT%H:%M"), data: { timezone_preview_target: "startsInput", action: "input->timezone-preview#refresh change->timezone-preview#refresh" } %>
      <p class="muted" data-timezone-preview-target="startsPreview">Stored as UTC: -</p>
    </div>

    <div>
      <%= form.label :ends_at %>
      <%= form.datetime_local_field :ends_at, value: tournament.ends_at&.in_time_zone(tournament.time_zone.presence || Tournament::DEFAULT_TIME_ZONE)&.strftime("%Y-%m-%dT%H:%M"), data: { timezone_preview_target: "endsInput", action: "input->timezone-preview#refresh change->timezone-preview#refresh" } %>
      <p class="muted" data-timezone-preview-target="endsPreview">Stored as UTC: -</p>
    </div>
  </div>
  <p class="muted">Starts/Ends are interpreted in the selected tournament timezone and stored in UTC.</p>

  <div class="card stack">
    <h2>Preset Rules</h2>
    <div>
      <%= label_tag :locked_time_control_preset_id, "Locked Preset" %>
      <%= select_tag :locked_time_control_preset_id,
        options_for_select([["None", ""]] + @available_presets.map { |preset| [preset.key, preset.id] }, @locked_preset_id),
        class: "input" %>
    </div>

    <div>
      <strong>Allowed Presets</strong>
      <% if @available_presets.empty? %>
        <p>No active presets available for selected game/rated settings.</p>
      <% else %>
        <div class="stack">
          <% @available_presets.each do |preset| %>
            <label>
              <%= check_box_tag "allowed_time_control_preset_ids[]", preset.id, @selected_preset_ids.include?(preset.id) %>
              <%= preset.key %> (<%= preset.category %>, <%= preset.clock_type %>)
            </label>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
