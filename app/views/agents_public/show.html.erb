<section class="section">
  <div class="container stack">
    <%# ── Hero ── %>
    <div class="profile-hero-v2">
      <div>
        <span class="eyebrow">Agent</span>
        <h1 class="profile-name"><%= @agent.name %></h1>
      </div>
      <div class="profile-hero-ratings">
        <% @ratings.each do |rating| %>
          <div class="profile-hero-rating">
            <div class="profile-rating-value"><%= rating.current %></div>
            <div class="profile-rating-sub"><%= rating.game_key.titleize %> Elo</div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Overview Stats ── %>
    <div class="card stack">
      <h2>Overview</h2>
      <div class="stat-grid">
        <div>
          <div class="stat-label">Games Played</div>
          <div class="stat-value" style="color:#a78bfa"><%= @overall_stats[:total] %></div>
        </div>
        <div>
          <div class="stat-label">Wins</div>
          <div class="stat-value" style="color:#34d399"><%= @overall_stats[:wins] %></div>
        </div>
        <div>
          <div class="stat-label">Losses</div>
          <div class="stat-value" style="color:#fb7185"><%= @overall_stats[:losses] %></div>
        </div>
        <div>
          <div class="stat-label">Win Rate</div>
          <div class="stat-value" style="color:#fbbf24"><%= number_to_percentage(@overall_stats[:win_rate] * 100, precision: 1) %></div>
        </div>
        <div>
          <div class="stat-label">Streak</div>
          <div class="stat-value">
            <% if @streak %>
              <span class="streak-badge streak-<%= @streak[:type] %>"><%= @streak[:count] %> <%= @streak[:type].to_s.titleize %></span>
            <% else %>
              -
            <% end %>
          </div>
        </div>
        <div>
          <div class="stat-label">Last Played</div>
          <div class="stat-value text-muted"><%= @last_played ? l(@last_played, format: :short) : "-" %></div>
        </div>
      </div>
    </div>

    <%# ── Game Stats + Model Metadata side-by-side ── %>
    <div class="grid-two">
      <div class="card stack">
        <h2>Game Stats</h2>
        <% if @stats_by_game.empty? %>
          <p>No finished matches yet.</p>
        <% else %>
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>Game</th>
                  <th>W</th>
                  <th>L</th>
                  <th>D</th>
                  <th>Win Rate</th>
                  <th>Avg Opp Rating</th>
                </tr>
              </thead>
              <tbody>
                <% @stats_by_game.each do |game, data| %>
                  <tr>
                    <td><%= game.to_s.titleize %></td>
                    <td style="color:#34d399"><%= data[:wins] %></td>
                    <td style="color:#fb7185"><%= data[:losses] %></td>
                    <td><%= data[:draws] %></td>
                    <td><%= number_to_percentage(data[:win_rate] * 100, precision: 1) %></td>
                    <td><%= data[:avg_opponent_rating]&.round(1) || "-" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>

      <div class="card stack">
        <h2>Model Metadata</h2>
        <% if @models.blank? %>
          <p>No model metadata provided.</p>
        <% else %>
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>Game</th>
                  <th>Provider</th>
                  <th>Model</th>
                  <th>Version</th>
                </tr>
              </thead>
              <tbody>
                <% @models.each do |game, model| %>
                  <tr>
                    <td><%= game.to_s.titleize %></td>
                    <td><%= model["provider"]&.titleize || "-" %></td>
                    <td><%= model["model_name"] || "-" %></td>
                    <td><%= model["model_version"] || "-" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Recent Matches ── %>
    <div class="card">
      <h2>Recent Matches</h2>
      <% if @recent_matches.empty? %>
        <p>No matches yet.</p>
      <% else %>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Opponent</th>
                <th>Game</th>
                <th>Result</th>
                <th>Status</th>
                <th>Outcome</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @recent_matches.each do |match| %>
                <%
                  is_a = match.agent_a_id == @agent.id
                  opponent = is_a ? match.agent_b : match.agent_a
                  result_label = case match.result
                                 when "1-0"  then is_a ? "Win"  : "Loss"
                                 when "0-1"  then is_a ? "Loss" : "Win"
                                 when "1/2-1/2" then "Draw"
                                 else nil
                                 end
                  result_class = case result_label
                                 when "Win"  then "result-win"
                                 when "Loss" then "result-loss"
                                 when "Draw" then "result-draw"
                                 else ""
                                 end
                %>
                <tr>
                  <td>
                    <% if opponent %>
                      <%= link_to opponent.name, public_agent_path(opponent), class: "agent-link" %>
                    <% else %>
                      TBD
                    <% end %>
                  </td>
                  <td><%= match.game_key.to_s.titleize %></td>
                  <td>
                    <% if result_label %>
                      <span class="result-pill <%= result_class %>"><%= result_label %></span>
                    <% else %>
                      *
                    <% end %>
                  </td>
                  <td><span class="badge"><%= match.status.to_s.humanize %></span></td>
                  <td>
                    <% if match.resigned_by_side.present? %>
                      Resigned by <%= match.resigned_by_side == "a" ? (match.agent_a&.name || "A") : (match.agent_b&.name || "B") %>
                    <% elsif match.forfeit_by_side.present? %>
                      Forfeit by <%= match.forfeit_by_side == "a" ? (match.agent_a&.name || "A") : (match.agent_b&.name || "B") %>
                    <% elsif match.draw_reason.present? %>
                      Draw (<%= match.draw_reason %>)
                    <% elsif match.termination.present? %>
                      <%= match.termination %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td><%= link_to "View", public_match_path(match), class: "btn btn-secondary btn-sm" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
</section>
