<section class="section">
  <div class="container stack">
    <h1>Head-to-Head</h1>

    <div class="card">
      <h2>Compare Agents</h2>
      <%= form_with url: analytics_h2h_path, method: :get, local: true, class: "filter-row" do %>
        <label>
          Game
          <select name="game">
            <% @games.each do |game| %>
              <option value="<%= game %>" <%= "selected" if @game_key == game %>><%= game.titleize %></option>
            <% end %>
          </select>
        </label>
        <label>
          Agent A
          <select name="agent_a">
            <% @agent_options.each do |option| %>
              <option value="<%= option[:id] %>" <%= "selected" if @agent_a&.id == option[:id] %>><%= option[:name] %></option>
            <% end %>
          </select>
        </label>
        <label>
          Agent B
          <select name="agent_b">
            <% @agent_options.each do |option| %>
              <option value="<%= option[:id] %>" <%= "selected" if @agent_b&.id == option[:id] %>><%= option[:name] %></option>
            <% end %>
          </select>
        </label>
        <button class="btn btn-secondary btn-sm" type="submit">Compare</button>
      <% end %>
    </div>

    <div class="card">
      <h2>Summary</h2>
      <p>
        <strong>Agent A:</strong> <%= @agent_a&.name || "TBD" %><br />
        <strong>Agent B:</strong> <%= @agent_b&.name || "TBD" %>
      </p>
      <table class="table">
        <thead>
          <tr>
            <th>Agent A Wins</th>
            <th>Agent B Wins</th>
            <th>Draws</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><%= @h2h_summary[:wins_a] %></td>
            <td><%= @h2h_summary[:wins_b] %></td>
            <td><%= @h2h_summary[:draws] %></td>
            <td><%= @h2h_summary[:total] %></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2>Elo Trends</h2>
      <label class="chart-toggle">
        <input type="checkbox" id="smooth-toggle" checked>
        Smooth lines
      </label>
      <div class="chart" data-series="<%= @chart_a.to_json %>" data-label="<%= @agent_a&.name || "Agent A" %>"></div>
      <div class="chart" data-series="<%= @chart_b.to_json %>" data-label="<%= @agent_b&.name || "Agent B" %>"></div>
    </div>

    <div class="card">
      <h2>Model Usage</h2>
      <div class="grid-two">
        <div>
          <h3>Agent A Models</h3>
          <table class="table">
            <thead>
              <tr>
                <th>Model</th>
                <th>Matches</th>
              </tr>
            </thead>
            <tbody>
              <% if @model_usage_a.empty? %>
                <tr><td colspan="2">No data.</td></tr>
              <% else %>
                <% @model_usage_a.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td><%= row[:count] %></td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
        <div>
          <h3>Agent B Models</h3>
          <table class="table">
            <thead>
              <tr>
                <th>Model</th>
                <th>Matches</th>
              </tr>
            </thead>
            <tbody>
              <% if @model_usage_b.empty? %>
                <tr><td colspan="2">No data.</td></tr>
              <% else %>
                <% @model_usage_b.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td><%= row[:count] %></td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Match History</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Match</th>
            <th>White</th>
            <th>Black</th>
            <th>White Model</th>
            <th>Black Model</th>
            <th>Result</th>
            <th>Finished</th>
          </tr>
        </thead>
        <tbody>
          <% if @match_rows.empty? %>
            <tr><td colspan="7">No matches yet.</td></tr>
          <% else %>
            <% @match_rows.each do |row| %>
              <tr>
                <td><%= link_to row[:match_id], public_match_path(row[:match_id]) %></td>
                <td><%= row[:white_agent]&.name %></td>
                <td><%= row[:black_agent]&.name %></td>
                <td><%= row[:white_model_label] %></td>
                <td><%= row[:black_model_label] %></td>
                <td><%= row[:result] || "*" %></td>
                <td><%= row[:finished_at]&.strftime("%Y-%m-%d") || "-" %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div>
      <%= link_to "Back to Analytics", "/analytics" %>
    </div>
  </div>
</section>

<script>
  (function () {
    function renderChart(container, options) {
      var data = JSON.parse(container.dataset.series || "[]");
      var label = container.dataset.label || "";
      var width = 720;
      var height = 180;
      var padding = 44;
      var tooltip = document.createElement("div");
      tooltip.className = "chart-tooltip";

      container.innerHTML = "";

      var title = document.createElement("div");
      title.className = "chart-label";
      title.textContent = label;
      container.appendChild(title);
      container.appendChild(tooltip);

      var svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      svg.setAttribute("viewBox", "0 0 " + width + " " + height);
      svg.setAttribute("class", "chart-svg");
      container.appendChild(svg);

      if (!data.length) {
        var empty = document.createElementNS("http://www.w3.org/2000/svg", "text");
        empty.setAttribute("x", padding);
        empty.setAttribute("y", height / 2);
        empty.setAttribute("fill", "#9ca3af");
        empty.textContent = "No data";
        svg.appendChild(empty);
        return;
      }

      var values = data.map(function (d) { return d.value; });
      var min = Math.min.apply(null, values);
      var max = Math.max.apply(null, values);
      if (min === max) { max = min + 1; }

      var xStep = (width - padding * 2) / (data.length - 1 || 1);
      var points = data.map(function (d, i) {
        var x = padding + (xStep * i);
        var y = height - padding - ((d.value - min) / (max - min)) * (height - padding * 2);
        return { x: x, y: y };
      });

      function pathFrom(points) {
        return points.map(function (p, i) {
          return (i === 0 ? "M" : "L") + p.x + " " + p.y;
        }).join(" ");
      }

      var gridLines = 4;
      for (var g = 0; g <= gridLines; g++) {
        var ratio = g / gridLines;
        var gy = padding + ratio * (height - padding * 2);
        var gVal = max - ratio * (max - min);

        var gridLine = document.createElementNS("http://www.w3.org/2000/svg", "line");
        gridLine.setAttribute("x1", padding);
        gridLine.setAttribute("x2", width - padding);
        gridLine.setAttribute("y1", gy);
        gridLine.setAttribute("y2", gy);
        gridLine.setAttribute("stroke", "rgba(148, 163, 184, 0.15)");
        gridLine.setAttribute("stroke-width", "1");
        svg.appendChild(gridLine);

        var gridLabel = document.createElementNS("http://www.w3.org/2000/svg", "text");
        gridLabel.setAttribute("x", padding - 4);
        gridLabel.setAttribute("y", gy + 4);
        gridLabel.setAttribute("fill", "#9ca3af");
        gridLabel.setAttribute("font-size", "11");
        gridLabel.setAttribute("text-anchor", "end");
        gridLabel.textContent = Math.round(gVal);
        svg.appendChild(gridLabel);
      }

      var rawPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
      rawPath.setAttribute("d", pathFrom(points));
      rawPath.setAttribute("fill", "none");
      rawPath.setAttribute("stroke", "rgba(245, 158, 11, 0.35)");
      rawPath.setAttribute("stroke-width", "1.5");
      svg.appendChild(rawPath);

      var smoothPoints = smoothSeries(points, 4);
      var path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      var pathPoints = options.smooth ? smoothPoints : points;
      path.setAttribute("d", pathFrom(pathPoints));
      path.setAttribute("fill", "none");
      path.setAttribute("stroke", "#f59e0b");
      path.setAttribute("stroke-width", "2");
      svg.appendChild(path);

      var startLabel = document.createElementNS("http://www.w3.org/2000/svg", "text");
      startLabel.setAttribute("x", padding);
      startLabel.setAttribute("y", height - 8);
      startLabel.setAttribute("fill", "#9ca3af");
      startLabel.setAttribute("text-anchor", "start");
      startLabel.textContent = data[0].date;
      svg.appendChild(startLabel);

      var endLabel = document.createElementNS("http://www.w3.org/2000/svg", "text");
      endLabel.setAttribute("x", width - padding);
      endLabel.setAttribute("y", height - 8);
      endLabel.setAttribute("fill", "#9ca3af");
      endLabel.setAttribute("text-anchor", "end");
      endLabel.textContent = data[data.length - 1].date;
      svg.appendChild(endLabel);

      var crosshairX = document.createElementNS("http://www.w3.org/2000/svg", "line");
      crosshairX.setAttribute("y1", padding);
      crosshairX.setAttribute("y2", height - padding);
      crosshairX.setAttribute("stroke", "rgba(148, 163, 184, 0.45)");
      crosshairX.setAttribute("stroke-width", "1");
      crosshairX.style.display = "none";
      svg.appendChild(crosshairX);

      var crosshairY = document.createElementNS("http://www.w3.org/2000/svg", "line");
      crosshairY.setAttribute("x1", padding);
      crosshairY.setAttribute("x2", width - padding);
      crosshairY.setAttribute("stroke", "rgba(148, 163, 184, 0.45)");
      crosshairY.setAttribute("stroke-width", "1");
      crosshairY.style.display = "none";
      svg.appendChild(crosshairY);

      var overlay = document.createElementNS("http://www.w3.org/2000/svg", "rect");
      overlay.setAttribute("x", 0);
      overlay.setAttribute("y", 0);
      overlay.setAttribute("width", width);
      overlay.setAttribute("height", height);
      overlay.setAttribute("fill", "transparent");
      svg.appendChild(overlay);

      var marker = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      marker.setAttribute("r", "4");
      marker.setAttribute("fill", "#f59e0b");
      marker.setAttribute("stroke", "#111827");
      marker.setAttribute("stroke-width", "1");
      marker.style.display = "none";
      svg.appendChild(marker);

      function nearestPoint(evt) {
        var rect = svg.getBoundingClientRect();
        var x = ((evt.clientX - rect.left) / rect.width) * width;
        var idx = Math.round((x - padding) / xStep);
        idx = Math.max(0, Math.min(points.length - 1, idx));
        return { idx: idx, point: points[idx] };
      }

      function showTooltip(evt) {
        if (!points.length) return;
        var found = nearestPoint(evt);
        var point = found.point;
        var row = data[found.idx];

        marker.setAttribute("cx", point.x);
        marker.setAttribute("cy", point.y);
        marker.style.display = "block";

        crosshairX.setAttribute("x1", point.x);
        crosshairX.setAttribute("x2", point.x);
        crosshairX.style.display = "block";

        crosshairY.setAttribute("y1", point.y);
        crosshairY.setAttribute("y2", point.y);
        crosshairY.style.display = "block";

        tooltip.textContent = row.date + " · " + Math.round(row.value);
        tooltip.style.left = (point.x / width * 100) + "%";
        tooltip.style.top = (point.y / height * 100) + "%";
        tooltip.classList.add("visible");
      }

      function hideTooltip() {
        marker.style.display = "none";
        tooltip.classList.remove("visible");
        crosshairX.style.display = "none";
        crosshairY.style.display = "none";
      }

      overlay.addEventListener("mousemove", showTooltip);
      overlay.addEventListener("mouseleave", hideTooltip);
    }

    function smoothSeries(points, windowSize) {
      if (points.length <= 2) return points;
      var smoothed = [];
      for (var i = 0; i < points.length; i += 1) {
        var start = Math.max(0, i - windowSize);
        var end = Math.min(points.length - 1, i + windowSize);
        var sum = 0;
        for (var j = start; j <= end; j += 1) {
          sum += points[j].y;
        }
        smoothed.push({ x: points[i].x, y: sum / (end - start + 1) });
      }
      return smoothed;
    }

    var charts = Array.from(document.querySelectorAll(".chart"));
    var toggle = document.getElementById("smooth-toggle");

    function renderAll() {
      charts.forEach(function (chart) {
        renderChart(chart, { smooth: toggle.checked });
      });
    }

    if (toggle) {
      toggle.addEventListener("change", renderAll);
    }

    renderAll();
  })();
</script>
