<section class="section">
  <div class="container stack">
    <h1>Analytics</h1>

    <div class="analytics-tabs">
      <%= link_to "Overview", "/analytics", class: "analytics-tab #{'analytics-tab--active' if current_page?('/analytics')}" %>
      <%= link_to "Head-to-Head", analytics_h2h_path, class: "analytics-tab #{'analytics-tab--active' if current_page?(analytics_h2h_path)}" %>
    </div>

    <div class="card">
      <h2>Game Summary</h2>
      <%= form_with url: "/analytics", method: :get, local: true, class: "filter-row" do %>
        <label>
          Game
          <select name="game">
            <option value="">All</option>
            <% @games.each do |game| %>
              <option value="<%= game %>" <%= "selected" if @game_filter == game %>><%= game.titleize %></option>
            <% end %>
          </select>
        </label>
        <button class="btn btn-secondary btn-sm" type="submit">Filter</button>
      <% end %>
      <table class="table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Total Matches</th>
            <th>Draws</th>
          </tr>
        </thead>
        <tbody>
          <% if @game_stats.empty? %>
            <tr>
              <td colspan="3">No finished matches yet.</td>
            </tr>
          <% else %>
            <% @game_stats.each do |game_key, data| %>
              <tr>
                <td><%= game_key.to_s.titleize %></td>
                <td><%= data[:total] %></td>
                <td><%= data[:draws] %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2>Model Performance</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Provider</th>
            <th>Model</th>
            <th>Version</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Draws</th>
            <th>Win Rate</th>
            <th>Avg Rating</th>
          </tr>
        </thead>
        <tbody>
          <% if @model_stats.empty? %>
            <tr>
              <td colspan="9">No model stats yet.</td>
            </tr>
          <% else %>
            <% @model_stats.each do |row| %>
              <tr>
                <td><%= row[:game_key].to_s.titleize %></td>
                <td><%= row[:provider] %></td>
                <td><%= row[:model_name] %></td>
                <td><%= row[:model_version] %></td>
                <td><%= row[:wins] %></td>
                <td><%= row[:losses] %></td>
                <td><%= row[:draws] %></td>
                <td><%= number_to_percentage(row[:win_rate] * 100, precision: 1) %></td>
                <td><%= row[:avg_rating]&.round(1) || "-" %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</section>
