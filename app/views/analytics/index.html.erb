<section class="section">
  <div class="container stack">
    <h1>Analytics</h1>

    <div class="card">
      <h2>Game Summary</h2>
      <%= form_with url: "/analytics", method: :get, local: true, class: "filter-row" do %>
        <label>
          Game
          <select name="game">
            <option value="">All</option>
            <% @games.each do |game| %>
              <option value="<%= game %>" <%= "selected" if @game_filter == game %>><%= game %></option>
            <% end %>
          </select>
        </label>
        <button class="btn btn-secondary btn-sm" type="submit">Filter</button>
      <% end %>
      <table class="table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Total Matches</th>
            <th>Draws</th>
          </tr>
        </thead>
        <tbody>
          <% if @game_stats.empty? %>
            <tr>
              <td colspan="3">No finished matches yet.</td>
            </tr>
          <% else %>
            <% @game_stats.each do |game_key, data| %>
              <tr>
                <td><%= game_key %></td>
                <td><%= data[:total] %></td>
                <td><%= data[:draws] %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2>Model Performance</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Provider</th>
            <th>Model</th>
            <th>Version</th>
            <th>Wins</th>
            <th>Losses</th>
            <th>Draws</th>
            <th>Win Rate</th>
            <th>Avg Rating</th>
          </tr>
        </thead>
        <tbody>
          <% if @model_stats.empty? %>
            <tr>
              <td colspan="9">No model stats yet.</td>
            </tr>
          <% else %>
            <% @model_stats.each do |row| %>
              <tr>
                <td><%= row[:game_key] %></td>
                <td><%= row[:provider] %></td>
                <td><%= row[:model_name] %></td>
                <td><%= row[:model_version] %></td>
                <td><%= row[:wins] %></td>
                <td><%= row[:losses] %></td>
                <td><%= row[:draws] %></td>
                <td><%= number_to_percentage(row[:win_rate] * 100, precision: 1) %></td>
                <td><%= row[:avg_rating]&.round(1) || "-" %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2>Head-to-Head</h2>
      <%= form_with url: "/analytics", method: :get, local: true, class: "filter-row" do %>
        <label>
          Game
          <select name="game">
            <option value="">All</option>
            <% @games.each do |game| %>
              <option value="<%= game %>" <%= "selected" if @game_filter == game %>><%= game %></option>
            <% end %>
          </select>
        </label>
        <button class="btn btn-secondary btn-sm" type="submit">Filter</button>
      <% end %>
      <table class="table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Model A</th>
            <th>Model B</th>
            <th>Model A Wins</th>
            <th>Model B Wins</th>
            <th>Draws</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          <% if @h2h_stats.empty? %>
            <tr>
              <td colspan="7">No head-to-head stats yet.</td>
            </tr>
          <% else %>
            <% @h2h_stats.each do |row| %>
              <tr>
                <td><%= row[:game_key] %></td>
                <td><%= row[:model_a][:label] %></td>
                <td><%= row[:model_b][:label] %></td>
                <td><%= row[:wins_a] %></td>
                <td><%= row[:wins_b] %></td>
                <td><%= row[:draws] %></td>
                <td>
                  <%= link_to row[:total], analytics_h2h_path(
                    game: row[:game_key],
                    a_provider: row[:model_a][:provider],
                    a_name: row[:model_a][:model_name],
                    a_version: row[:model_a][:model_version],
                    b_provider: row[:model_b][:provider],
                    b_name: row[:model_b][:model_name],
                    b_version: row[:model_b][:model_version]
                  ) %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>
