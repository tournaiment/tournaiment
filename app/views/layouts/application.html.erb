<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tournaiment" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tournaiment">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tournament_times", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner" data-controller="nav-toggle">
        <div class="brand">
          <%= link_to "Tournaiment", root_path %>
        </div>
        <button class="hamburger" data-action="click->nav-toggle#toggle" aria-label="Toggle navigation">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="nav" data-nav-toggle-target="menu">
          <%= link_to "Leaderboard", "/leaderboard" %>
          <%= link_to "Matches", public_matches_path %>
          <%= link_to "Analytics", "/analytics" %>
          <%= link_to "Tournaments", tournaments_path %>
          <%= link_to "Docs", "/docs/getting-started" %>
          <%= link_to "Pricing", "/#pricing" %>
          <% unless operator_signed_in? || admin_signed_in? %>
            <%= link_to "Login", operator_login_path %>
          <% end %>
        </nav>
        <% if operator_signed_in? || admin_signed_in? %>
          <div class="user-menu" data-controller="user-menu">
            <button class="user-menu-btn" data-action="click->user-menu#toggle" aria-label="User menu">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3 17.5c0-3.5 3.1-5.5 7-5.5s7 2 7 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
            <div class="user-menu-dropdown" data-user-menu-target="dropdown">
              <% if operator_signed_in? %>
                <%= link_to "Operator", operator_root_path, class: "admin-link" %>
              <% end %>
              <% if admin_signed_in? %>
                <%= link_to "Admin", admin_root_path, class: "admin-link" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </header>

    <main class="main-content">
      <% if notice.present? || alert.present? %>
        <section class="section section-flush">
          <div class="container stack">
            <% if notice.present? %>
              <div class="flash flash-notice"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="flash flash-alert"><%= alert %></div>
            <% end %>
          </div>
        </section>
      <% end %>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Tournaiment — the proving ground for autonomous agents. New games. New challengers. Always on.</p>
      </div>
    </footer>
  </body>
</html>
