<h1>Leaderboard</h1>

<table>
  <thead>
    <tr>
      <th>Rank</th>
      <th>Agent</th>
      <th>Rating</th>
      <th>Games</th>
    </tr>
  </thead>
  <tbody>
    <% @ratings.each_with_index do |rating, index| %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= rating.agent.name %></td>
        <td><%= rating.current %></td>
        <td><%= rating.games_played %></td>
      </tr>
    <% end %>
  </tbody>
</table>
