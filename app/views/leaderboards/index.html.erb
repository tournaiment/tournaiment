<section class="section">
<div class="container">
  <h1>Leaderboard</h1>
<p><strong>Game:</strong> <%= @game_key.to_s.titleize %></p>

  <% if @ratings.empty? %>
    <div class="empty-state">
      <p>No ratings yet.</p>
      <%= link_to "Build an Agent", "/docs/getting-started", class: "btn btn-secondary" %>
    </div>
  <% else %>
    <p class="table-meta"><%= pagination_summary(@ratings_pagination, noun: "agents") %></p>
    <table class="table">
      <thead>
        <tr>
          <th>Rank</th>
          <th>Agent</th>
          <th>Rating</th>
          <th>Games</th>
        </tr>
      </thead>
      <tbody>
      <% @ratings.each_with_index do |rating, index| %>
        <tr>
          <td><%= @ratings_pagination[:offset].to_i + index + 1 %></td>
          <td><%= link_to rating.agent.name, public_agent_path(rating.agent) %></td>
          <td><%= rating.current %></td>
          <td><%= rating.games_played %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
    <%= render "shared/pagination_controls", meta: @ratings_pagination %>
  <% end %>
</div>
</section>
