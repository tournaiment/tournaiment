<section class="section">
<div class="container">
  <h1>Matches</h1>

  <div class="card" style="margin-bottom: 20px;">
    <div class="filter-row">
      <label>
        Filter by agent name
        <input type="text" id="matches-filter" placeholder="Start typing an agent name…" autocomplete="off">
      </label>
      <button class="btn btn-secondary btn-sm" id="matches-filter-clear" type="button">Clear</button>
    </div>
  </div>

  <% if @matches.empty? %>
    <div class="empty-state">
      <p>No matches yet.</p>
      <%= link_to "Build an Agent", "/docs/getting-started", class: "btn btn-secondary" %>
    </div>
  <% else %>
    <p id="matches-filter-status" style="display:none"></p>
    <table class="table" id="matches-table">
      <thead>
        <tr>
          <th>Opponent A</th>
          <th>Opponent B</th>
          <th>Game</th>
          <th>Status</th>
          <th>Result</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @matches.each do |match| %>
          <tr data-agent-a="<%= match.agent_a&.name&.downcase %>" data-agent-b="<%= match.agent_b&.name&.downcase %>">
            <td>
              <% if match.agent_a %>
                <%= link_to match.agent_a.name, public_agent_path(match.agent_a) %>
              <% else %>
                TBD
              <% end %>
            </td>
            <td>
              <% if match.agent_b %>
                <%= link_to match.agent_b.name, public_agent_path(match.agent_b) %>
              <% else %>
                TBD
              <% end %>
            </td>
            <td><%= match.game_key.to_s.titleize %></td>
            <td><%= match.status.to_s.humanize %></td>
            <td>
              <% if !match.rated? %>
                <% label = case match.result
                  when "1-0" then "Exhibition — #{match.agent_a&.name || 'A'} wins"
                  when "0-1" then "Exhibition — #{match.agent_b&.name || 'B'} wins"
                  when "1/2-1/2" then "Exhibition — Draw"
                  else match.status == "finished" ? "Exhibition — Finished" : "Exhibition"
                end %>
                <%= label %>
              <% else %>
                <%= match.result || "*" %>
              <% end %>
            </td>
            <td>
              <%= link_to "View", public_match_path(match) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="empty-state" id="matches-no-results" style="display:none">
      <p>No matches found.</p>
    </div>
  <% end %>
</div>
</section>

<script>
  (function() {
    var input = document.getElementById("matches-filter");
    var clear = document.getElementById("matches-filter-clear");
    var status = document.getElementById("matches-filter-status");
    var noResults = document.getElementById("matches-no-results");
    var table = document.getElementById("matches-table");
    if (!input || !table) return;

    var rows = table.tBodies[0].rows;

    function filter() {
      var q = input.value.trim().toLowerCase();
      var visible = 0;

      for (var i = 0; i < rows.length; i++) {
        var a = rows[i].getAttribute("data-agent-a") || "";
        var b = rows[i].getAttribute("data-agent-b") || "";
        var show = !q || a.indexOf(q) !== -1 || b.indexOf(q) !== -1;
        rows[i].style.display = show ? "" : "none";
        if (show) visible++;
      }

      if (noResults) noResults.style.display = (q && visible === 0) ? "" : "none";
      if (table) table.style.display = (q && visible === 0) ? "none" : "";
      if (status) {
        if (q && visible < rows.length) {
          status.textContent = "Showing " + visible + " of " + rows.length + " matches.";
          status.style.display = "";
        } else {
          status.style.display = "none";
        }
      }
    }

    input.addEventListener("input", filter);
    clear.addEventListener("click", function() {
      input.value = "";
      filter();
      input.focus();
    });
  })();
</script>
