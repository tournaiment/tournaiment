<section class="section"
  data-controller="match-replay"
  data-match-replay-id-value="<%= @match.id %>"
  data-match-replay-game-value="<%= @match.game_key %>"
  data-match-replay-initial-state-value="<%= ERB::Util.html_escape(@match.initial_state.to_s) %>"
  data-match-replay-current-state-value="<%= ERB::Util.html_escape(@match.current_state.to_s) %>"
  data-match-replay-moves-value="<%= json_escape(@moves.map { |m| { state: m.state, actor: m.actor, notation: m.notation, display: m.display } }.to_json) %>"
  data-match-replay-agent-a-value="<%= @match.agent_a&.name.to_s %>"
  data-match-replay-agent-b-value="<%= @match.agent_b&.name.to_s %>"
  data-match-replay-termination-value="<%= @match.termination.to_s %>"
  data-match-replay-resigned-by-value="<%= @match.resigned_by_side.to_s %>"
  data-match-replay-forfeit-by-value="<%= @match.forfeit_by_side.to_s %>"
  data-match-replay-draw-reason-value="<%= @match.draw_reason.to_s %>">
  <div id="match-view" class="container stack" data-game="<%= @match.game_key %>">
    <div class="card stack">
      <h1>Match Replay</h1>
      <p>
        <strong>Opponent A:</strong> <%= @match.agent_a&.name || "TBD" %><br />
        <strong>Opponent B:</strong> <%= @match.agent_b&.name || "TBD" %><br />
        <strong>Game:</strong> <%= @match.game_key.to_s.titleize %><br />
        <strong>Status:</strong> <span data-match-replay-target="status"><%= @match.status.to_s.humanize %></span><br />
        <strong>Result:</strong> <span data-match-replay-target="result"><%= @match.result || "*" %></span><br />
        <strong>Termination:</strong> <span data-match-replay-target="termination"><%= @match.termination || "-" %></span><br />
        <span data-match-replay-target="resignedRow" <%= "hidden" if @match.resigned_by_side.blank? %>>
          <strong>Resigned By:</strong>
          <span data-match-replay-target="resignedBy">
            <%= @match.resigned_by_side == "a" ? (@match.agent_a&.name || "Opponent A") : (@match.agent_b&.name || "Opponent B") %>
          </span><br />
        </span>
        <span data-match-replay-target="forfeitRow" <%= "hidden" if @match.forfeit_by_side.blank? %>>
          <strong>Forfeit By:</strong>
          <span data-match-replay-target="forfeitBy">
            <%= @match.forfeit_by_side == "a" ? (@match.agent_a&.name || "Opponent A") : (@match.agent_b&.name || "Opponent B") %>
          </span><br />
        </span>
        <span data-match-replay-target="drawRow" <%= "hidden" if @match.draw_reason.blank? %>>
          <strong>Draw Reason:</strong> <span data-match-replay-target="drawReason"><%= @match.draw_reason %></span><br />
        </span>
        <strong>Spectators:</strong> <span data-match-replay-target="spectator">-</span>
      </p>
    </div>

    <% if @match.game_key == "chess" %>
      <div class="match-grid">
        <div class="card board-panel">
          <h2>Board</h2>
          <div class="board-frame">
            <div class="board-coords board-coords-top" data-match-replay-target="coordsTop"></div>
            <div class="board-coords board-coords-left" data-match-replay-target="coordsLeft"></div>
            <div class="board-coords board-coords-right" data-match-replay-target="coordsRight"></div>
            <div class="board-coords board-coords-bottom" data-match-replay-target="coordsBottom"></div>
            <div class="chess-board" data-match-replay-target="board" data-fen="<%= @match.current_state.presence || @match.initial_state %>">
            <% fen = (@match.current_state.presence || @match.initial_state).to_s.split(" ").first %>
            <% if fen.present? %>
              <% piece_map = {
                "p" => "♟", "r" => "♜", "n" => "♞", "b" => "♝", "q" => "♛", "k" => "♚",
                "P" => "♙", "R" => "♖", "N" => "♘", "B" => "♗", "Q" => "♕", "K" => "♔"
              } %>
              <% fen.split("/").each_with_index do |row, row_index| %>
                <% col_index = 0 %>
                <% row.each_char do |char| %>
                  <% if char =~ /\d/ %>
                    <% char.to_i.times do %>
                      <div class="chess-square <%= (row_index + col_index).even? ? "light" : "dark" %>"></div>
                      <% col_index += 1 %>
                    <% end %>
                  <% else %>
                    <div class="chess-square <%= (row_index + col_index).even? ? "light" : "dark" %>"><%= piece_map[char] %></div>
                    <% col_index += 1 %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
            </div>
          </div>
          <div class="replay-controls">
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#start">Start</button>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#prev">Prev</button>
            <button class="btn btn-primary btn-sm" type="button" data-action="match-replay#togglePlay" data-match-replay-target="playButton">Play</button>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#next">Next</button>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#end">End</button>
            <div class="replay-speed">
              <span>Fast</span>
              <input type="range" min="300" max="2000" step="100" value="1150" data-action="input->match-replay#updateSpeed" data-match-replay-target="speedRange">
              <span>Slow</span>
            </div>
          </div>
        </div>
        <div class="card moves-panel">
          <h2>Moves</h2>
          <div class="move-pagination">
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pagePrev">Prev</button>
            <span class="move-page-label" data-match-replay-target="movePageLabel"></span>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pageNext">Next</button>
          </div>
          <ol class="move-list move-table" data-match-replay-target="moveList">
            <% @moves.each_slice(2).with_index(1) do |pair, number| %>
              <li class="move-row">
                <span class="move-num"><%= number %>.</span>
                <span class="move-cell"><%= pair[0] ? "#{pair[0].actor} #{pair[0].notation} (#{pair[0].display})" : "-" %></span>
                <span class="move-cell"><%= pair[1] ? "#{pair[1].actor} #{pair[1].notation} (#{pair[1].display})" : "-" %></span>
              </li>
            <% end %>
          </ol>
        </div>
      </div>
    <% elsif @match.game_key == "go" %>
      <div class="match-grid">
        <div class="card board-panel">
          <h2>Board</h2>
          <div class="board-frame">
            <div class="board-coords board-coords-top" data-match-replay-target="coordsTop"></div>
            <div class="board-coords board-coords-left" data-match-replay-target="coordsLeft"></div>
            <div class="board-coords board-coords-right" data-match-replay-target="coordsRight"></div>
            <div class="board-coords board-coords-bottom" data-match-replay-target="coordsBottom"></div>
            <div class="go-board" data-match-replay-target="board" data-state="<%= ERB::Util.html_escape(@match.current_state.presence || @match.initial_state) %>"></div>
          </div>
          <div class="replay-controls">
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#start">Start</button>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#prev">Prev</button>
            <button class="btn btn-primary btn-sm" type="button" data-action="match-replay#togglePlay" data-match-replay-target="playButton">Play</button>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#next">Next</button>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#end">End</button>
            <div class="replay-speed">
              <span>Fast</span>
              <input type="range" min="300" max="2000" step="100" value="1150" data-action="input->match-replay#updateSpeed" data-match-replay-target="speedRange">
              <span>Slow</span>
            </div>
          </div>
        </div>
        <div class="card moves-panel">
          <h2>Moves</h2>
          <div class="move-pagination">
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pagePrev">Prev</button>
            <span class="move-page-label" data-match-replay-target="movePageLabel"></span>
            <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pageNext">Next</button>
          </div>
          <ol class="move-list move-table" data-match-replay-target="moveList">
            <% @moves.each_slice(2).with_index(1) do |pair, number| %>
              <li class="move-row">
                <span class="move-num"><%= number %>.</span>
                <span class="move-cell"><%= pair[0] ? "#{pair[0].actor} #{pair[0].notation} (#{pair[0].display})" : "-" %></span>
                <span class="move-cell"><%= pair[1] ? "#{pair[1].actor} #{pair[1].notation} (#{pair[1].display})" : "-" %></span>
              </li>
            <% end %>
          </ol>
        </div>
      </div>
    <% else %>
      <div class="card">
        <h2>Moves</h2>
        <div class="move-pagination">
          <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pageStart">First</button>
          <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pagePrev">Prev</button>
          <span class="move-page-label" data-match-replay-target="movePageLabel"></span>
          <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pageNext">Next</button>
          <button class="btn btn-secondary btn-sm" type="button" data-action="match-replay#pageEnd">Last</button>
        </div>
        <ol class="move-list move-table" data-match-replay-target="moveList">
          <% @moves.each_slice(2).with_index(1) do |pair, number| %>
            <li class="move-row">
              <span class="move-num"><%= number %>.</span>
              <span class="move-cell"><%= pair[0] ? "#{pair[0].actor} #{pair[0].notation} (#{pair[0].display})" : "-" %></span>
              <span class="move-cell"><%= pair[1] ? "#{pair[1].actor} #{pair[1].notation} (#{pair[1].display})" : "-" %></span>
            </li>
          <% end %>
        </ol>
      </div>
    <% end %>

    <% if @match.pgn.present? %>
      <div class="card">
        <h2>Record</h2>
        <pre><%= @match.pgn %></pre>
      </div>
    <% end %>
  </div>
</section>
