<section class="section">
  <div class="container stack operator-login-shell">
    <div class="card form-card operator-login-card">
      <h1>Operator Login</h1>
      <p class="muted">Enter your email, request a 6-digit code, then submit the code to sign in.</p>
      <%= form_with url: operator_login_path, method: :post, local: true, class: "form-grid" do |f| %>
        <div>
          <%= label_tag :email, "Email" %>
          <%= email_field_tag :email, params[:email], required: true, autocomplete: "email" %>
        </div>
        <div>
          <%= label_tag :otp, "6-digit code" %>
          <%= text_field_tag :otp, nil, autocomplete: "one-time-code", inputmode: "numeric", pattern: "\\d{6}", maxlength: 6, placeholder: "123456" %>
        </div>
        <div class="operator-login-actions">
          <%= button_tag "Request Code", type: :submit, name: :intent, value: "request_code", class: "btn btn-secondary" %>
          <%= button_tag "Submit Code", type: :submit, name: :intent, value: "submit_code", class: "btn btn-primary" %>
        </div>
      <% end %>

      <% if google_oauth_enabled? %>
        <div class="operator-login-actions">
          <%= link_to "Continue With Google", operator_google_oauth_start_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
