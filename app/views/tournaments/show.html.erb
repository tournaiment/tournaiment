<section class="section">
  <div class="container stack">
    <h1><%= @tournament.name %></h1>

    <div class="card stack">
      <p><%= @tournament.description.presence || "No description yet." %></p>

      <div class="match-info-grid">
        <div>
          <div class="stat-label">Status</div>
          <div class="stat-value"><span class="status-badge status-<%= @tournament.status %>"><%= @tournament.status.to_s.humanize %></span></div>
        </div>
        <div>
          <div class="stat-label">Game</div>
          <div class="stat-value"><%= @tournament.game_key.to_s.titleize %></div>
        </div>
        <div>
          <div class="stat-label">Format</div>
          <div class="stat-value"><%= @tournament.format.humanize %></div>
        </div>
        <div>
          <div class="stat-label">Time Control</div>
          <div class="stat-value"><%= @tournament.time_control %></div>
        </div>
        <div>
          <div class="stat-label">Rated</div>
          <div class="stat-value"><%= @tournament.rated ? "Yes" : "No" %></div>
        </div>
        <div>
          <div class="stat-label">Cash Prize</div>
          <div class="stat-value"><%= @tournament.monied ? "Yes" : "No" %></div>
        </div>
        <div>
          <div class="stat-label">Starts</div>
          <div class="stat-value"><%= dual_datetime_display(@tournament.starts_at, tournament_time_zone: @tournament.time_zone) %></div>
        </div>
        <div>
          <div class="stat-label">Ends</div>
          <div class="stat-value"><%= dual_datetime_display(@tournament.ends_at, tournament_time_zone: @tournament.time_zone) %></div>
        </div>
        <div>
          <div class="stat-label">Max Players</div>
          <div class="stat-value"><%= @tournament.max_players || "Open" %></div>
        </div>
        <div>
          <div class="stat-label">Registered</div>
          <div class="stat-value"><%= @tournament.registered_count %></div>
        </div>
      </div>

      <div class="cta-row">
        <%= link_to "View Bracket", bracket_tournament_path(@tournament), class: "btn btn-secondary" %>
        <%= link_to "View Table", table_tournament_path(@tournament), class: "btn btn-secondary" %>
      </div>
    </div>

    <%= render "bracket_board", rounds: @bracket_rounds, heading: (@tournament.format == "round_robin" ? "Fixtures" : "Bracket") %>
  </div>
</section>
