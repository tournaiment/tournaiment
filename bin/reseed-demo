#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"

APP_ROOT = File.expand_path("..", __dir__)

MODE_DEMO_REFRESH = "demo_refresh"
MODE_GAMEPLAY_RESET = "gameplay_reset"
MODE_FULL_RESET = "full_reset"
VALID_MODES = [ MODE_DEMO_REFRESH, MODE_GAMEPLAY_RESET, MODE_FULL_RESET ].freeze

MODE_CHOICES = {
  "1" => MODE_DEMO_REFRESH,
  "2" => MODE_GAMEPLAY_RESET,
  "3" => MODE_FULL_RESET
}.freeze

def run!(env:, command:, extra_env: {})
  merged_env = { "RAILS_ENV" => env }.merge(extra_env.transform_values(&:to_s))
  puts "==> #{command}"
  system(merged_env, command, exception: true)
end

def choose_mode_interactively
  puts "Choose reseed mode:"
  puts "  1. Demo refresh (delete demo-only data, keep non-demo data, reseed demo)"
  puts "  2. Gameplay reset (clear matches/tournaments/ratings/audit data, reseed demo)"
  puts "  3. Full DB reset (drop + recreate DB, migrate, reseed demo)"
  print "> "
  input = $stdin.gets&.strip
  return nil if input.nil? || input.empty?
  return nil if %w[q quit exit].include?(input.downcase)

  MODE_CHOICES.fetch(input, input)
end

def confirm!(message, expected: "yes")
  print "#{message} "
  answer = $stdin.gets&.strip
  return if answer == expected

  puts "Aborted."
  exit(1)
end

def print_header(env:, mode:, agents:, matches:, real_ratio:)
  puts "Tournaiment reseed helper"
  puts "  Environment: #{env}"
  puts "  Mode: #{mode}"
  puts "  Agents: #{agents}"
  puts "  Matches: #{matches}"
  puts "  Real games ratio: #{real_ratio}"
end

options = {
  env: ENV.fetch("RAILS_ENV", "development"),
  mode: nil,
  yes: false,
  agents: ENV.fetch("SEED_AGENTS", "12"),
  matches: ENV.fetch("SEED_MATCHES", "300"),
  real_ratio: ENV.fetch("SEED_REAL_GAMES_RATIO", "0.45")
}

OptionParser.new do |opts|
  opts.banner = "Usage: bin/reseed-demo [options]"

  opts.on("--env ENV", "Rails env (default: development)") do |value|
    options[:env] = value
  end

  opts.on("--mode MODE", "Mode: #{VALID_MODES.join(", ")}") do |value|
    options[:mode] = value
  end

  opts.on("--agents N", Integer, "Demo agent count (default: 12)") do |value|
    options[:agents] = value.to_i.to_s
  end

  opts.on("--matches N", Integer, "Demo match count (default: 300)") do |value|
    options[:matches] = value.to_i.to_s
  end

  opts.on("--real-ratio R", Float, "Real game ratio 0.0..1.0 (default: 0.45)") do |value|
    clamped = [ [ value, 0.0 ].max, 1.0 ].min
    options[:real_ratio] = clamped.to_s
  end

  opts.on("--yes", "Skip confirmations") do
    options[:yes] = true
  end
end.parse!

Dir.chdir(APP_ROOT) do
  if options[:mode].nil?
    if $stdin.tty?
      options[:mode] = choose_mode_interactively
    else
      puts "Non-interactive shell: pass --mode #{VALID_MODES.join("|")}"
      exit(1)
    end
  end

  mode = options[:mode]
  unless VALID_MODES.include?(mode)
    puts "Invalid mode: #{mode}. Valid: #{VALID_MODES.join(", ")}"
    exit(1)
  end

  if options[:agents].to_i < 8
    puts "SEED_AGENTS=#{options[:agents]} is too low for full demo tournament coverage. Using 8."
    options[:agents] = "8"
  end

  print_header(
    env: options[:env],
    mode: mode,
    agents: options[:agents],
    matches: options[:matches],
    real_ratio: options[:real_ratio]
  )

  common_seed_env = {
    "SEED_DEMO" => "1",
    "SEED_AGENTS" => options[:agents],
    "SEED_MATCHES" => options[:matches],
    "SEED_REAL_GAMES_RATIO" => options[:real_ratio]
  }

  case mode
  when MODE_DEMO_REFRESH
    run!(env: options[:env], command: "ruby script/clear_demo_data.rb", extra_env: { "DRY_RUN" => "1" })
    confirm!("Proceed with demo refresh? Type 'yes' to continue:", expected: "yes") unless options[:yes]
    run!(env: options[:env], command: "ruby script/clear_demo_data.rb", extra_env: { "AUTO_CONFIRM" => "1" })
    run!(env: options[:env], command: "bin/rails db:seed", extra_env: common_seed_env)
  when MODE_GAMEPLAY_RESET
    confirm!("This resets gameplay data (matches/tournaments/ratings/audit logs). Type 'RESET' to continue:", expected: "RESET") unless options[:yes]
    run!(
      env: options[:env],
      command: "bin/rails db:seed",
      extra_env: common_seed_env.merge("SEED_DEMO_FORCE" => "1")
    )
  when MODE_FULL_RESET
    confirm!("This drops and recreates the entire #{options[:env]} database. Type 'DROP' to continue:", expected: "DROP") unless options[:yes]
    run!(env: options[:env], command: "bin/rails db:drop db:create db:migrate")
    run!(env: options[:env], command: "bin/rails db:seed", extra_env: common_seed_env)
  end

  puts "Done."
  run!(
    env: options[:env],
    command: "bin/rails runner 'puts Tournament.where(\"name LIKE ?\", \"Demo %\").group(:status).count'"
  )
end
